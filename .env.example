# Hermes Fusion Environment Variables
# Copy to .env and fill in your API keys
# NEVER commit .env with real keys!

# Cloud LLM Providers (optional - only needed for cloud providers)
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LocalAI (EUREKAI) - no key needed, uses local endpoint
# LOCALAI_BASE_URL=http://192.168.1.47:8080

# Qdrant (EUREKAI) - no key needed by default
# QDRANT_URL=http://192.168.1.47:6333

# Hailo-8 (EUREKAI) - no key needed
# HAILO_HOST=192.168.1.47
# HAILO_PORT=8767

# Optional: Custom provider keys
# MY_PROVIDER_KEY=your_custom_key